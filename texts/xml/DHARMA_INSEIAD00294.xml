                    </app>
                    <app loc="2">
                        <lem>Imaṁ paṁdaka</lem>
                        <rdg source="bib:Burgess1882_01">mahadaka-</rdg>
                    </app>
                    <app loc="2">
                        <lem>paṁdaka</lem>
                        <rdg source="bib:Hultzsch1886_01">peṁḍak<unclear>o</unclear></rdg>
                        <rdg source="bib:Burgess1887_01 bib:Luders1912_01">peṁḍaka</rdg>
                        <rdg source="bib:Sivaramamurti1942_01">peṇḍaka</rdg>
                        <rdg source="bib:Barrett1990_01"/>
                    </app>
                    <app loc="2">
                        <lem>padaka</lem>
                        <rdg source="bib:Barrett1990_01"><choice><orig>padaka</orig><reg>pendaka</reg></choice></rdg>
                    </app>
                    <app loc="2">
                        <lem>patiṭha<supplied reason="lost">p</supplied><unclear>i</unclear><add place="below">ta</add></lem>
                        <rdg source="bib:Hultzsch1886_01 bib:Burgess1887_01 bib:Sivaramamurti1942_01"/>
                        <rdg source="bib:Burgess1882_01">-patitha <gap reason="lost" quantity="1" unit="character"/> A</rdg>
                    </app>
                </listApp>
            </div>
            <div type="translation">
                <p><supplied reason="lost">Homage to</supplied> the Bhagavant! This <seg cert="low">upright</seg> is set up by the nun Vadā, a resident of Kavurura, <supplied reason="subaudible">as well as</supplied> by Aṅgī, Bodhī, Bhāyitī and Utā.</p>
            </div>
